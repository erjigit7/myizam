# --- База (docker-compose поднимает pgvector с этими значениями) ---
POSTGRES_DB=myizam
POSTGRES_USER=myizam
POSTGRES_PASSWORD=myizam
DATABASE_URL=Host=localhost;Port=5432;Database=myizam;Username=myizam;Password=myizam

# --- Эмбеддинги (ТЗ v2.1 §1.1): разработка на B (ollama), прод-решение перед деплоем ---
# Вариант B: локальный Ollama + bge-m3 (dim 1024, бесплатно)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
OLLAMA_URL=http://localhost:11434
# Вариант A: OpenAI (dim 1536; сменить EMBEDDING_DIM = новая миграция + переиндексация!)
#EMBEDDING_PROVIDER=openai
#EMBEDDING_MODEL=text-embedding-3-small
#EMBEDDING_DIM=1536
#OPENAI_API_KEY=sk-...

# --- LLM (фаза 3) ---
#OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini

# --- ML sidecar (фаза 2) ---
ML_URL=http://localhost:8000
GUARD_MODELS=kg
GUARD_MODE=shadow

# --- Пайплайн /api/ask (фаза 3; калибруется в фазе 4) ---
MIN_SIMILARITY=0.35
RATE_LIMIT_DAILY=5
RATE_LIMIT_PER_MINUTE=3
CLIENT_HASH_SALT=change-me
CORS_ORIGINS=http://localhost:4200
